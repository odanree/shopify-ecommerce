# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Product Variant IDs (get from Shopify Admin → Products → Variants)
NEXT_PUBLIC_VARIANT_PRIMARY_SIM=your_primary_sim_variant_id
NEXT_PUBLIC_VARIANT_PRIMARY_ESIM=your_primary_esim_variant_id
NEXT_PUBLIC_VARIANT_ADDON_SIM=your_addon_sim_variant_id
NEXT_PUBLIC_VARIANT_ADDON_ESIM=your_addon_esim_variant_id
